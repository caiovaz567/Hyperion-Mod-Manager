{
  "name": "hyperion",
  "version": "0.7.0",
  "description": "Cyberpunk 2077 Mod Manager",
  "main": "out/main/index.js",
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run clean:dist && npm run build && electron-builder",
    "preview:win": "npm run clean:dist && npm run build && electron-builder --win dir --publish never",
    "dist": "npm run clean:dist && npm run build && electron-builder --win nsis --publish never",
    "dist:publish": "npm run clean:dist && npm run build && electron-builder --win nsis --publish always",
    "release:patch": "npm version patch -m \"release: %s\"",
    "release:minor": "npm version minor -m \"release: %s\"",
    "release:major": "npm version major -m \"release: %s\""
  },
  "keywords": [
    "cyberpunk",
    "mod",
    "manager",
    "electron"
  ],
  "author": "",
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "7zip-bin-full": "^26.0.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^5.16.1",
    "@mui/material": "^5.16.1",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "build": {
    "appId": "com.hyperion.modmanager",
    "productName": "Hyperion",
    "executableName": "Hyperion",
    "copyright": "Copyright © 2024",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "src/main/resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/7z.exe",
        "to": "tools/7zip/7z.exe"
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/7z.dll",
        "to": "tools/7zip/7z.dll"
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/License.txt",
        "to": "tools/7zip/License.txt"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "caiomarcelo567",
      "repo": "Hyperion-Mod-Manager"
    }
  }
}
