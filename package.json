{
  "name": "hyperion",
  "version": "0.32.0",
  "description": "Cyberpunk 2077 Mod Manager",
  "main": "out/main/index.js",
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "dev": "electron-vite dev",
    "fetch:usvfs": "node scripts/fetch-usvfs.mjs",
    "build:native": "node scripts/build-native.mjs",
    "build": "npm run clean:dist && electron-vite build && npm run build:native && electron-builder --win nsis --publish never",
    "preview": "electron-vite preview",
    "package": "npm run clean:dist && electron-vite build && npm run build:native && electron-builder",
    "preview:win": "npm run clean:dist && electron-vite build && npm run build:native && electron-builder --win dir --publish never",
    "publish": "npm run clean:dist && electron-vite build && npm run build:native && electron-builder --win nsis --publish always",
    "release:patch": "node scripts/prepare-release-tag.mjs patch",
    "release:minor": "node scripts/prepare-release-tag.mjs minor",
    "release:major": "node scripts/prepare-release-tag.mjs major",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cyberpunk",
    "mod",
    "manager",
    "electron"
  ],
  "author": "",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "7zip-bin-full": "^26.0.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.10.6",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^11.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/oxanium": "^5.2.8",
    "@fontsource/syne": "^5.2.7",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^10.0.0",
    "zustand": "^4.5.4"
  },
  "overrides": {
    "cacache": {
      "glob": "^13.0.0"
    },
    "yauzl": "^3.0.0"
  },
  "build": {
    "appId": "com.hyperion.modmanager",
    "productName": "Hyperion",
    "executableName": "Hyperion",
    "copyright": "Copyright © 2024",
    "icon": "build/icon.ico",
    "afterPack": "./scripts/after-pack.cjs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "src/main/resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/7z.exe",
        "to": "tools/7zip/7z.exe"
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/7z.dll",
        "to": "tools/7zip/7z.dll"
      },
      {
        "from": "node_modules/7zip-bin-full/win/x64/License.txt",
        "to": "tools/7zip/License.txt"
      },
      {
        "from": "native/usvfs-bridge/build/Release",
        "to": "usvfs",
        "filter": [
          "usvfs_bridge.node",
          "usvfs_x64.dll",
          "usvfs_proxy_x64.exe"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "caiovaz567",
      "repo": "Hyperion-Mod-Manager"
    }
  }
}
